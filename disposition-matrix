<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Warhammer 40K 11th Edition Force Disposition Matrix</title>
    <style>
        :root {
            --bg-dark: #0a0f14;
            --panel-bg: #121a22;
            --border-color: #243545;
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --accent-green: #22c55e;
            --accent-red: #ef4444;
            --faction-highlight: #38bdf8;
            --btn-active-blue: #1d4ed8;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            padding: 2rem;
            line-height: 1.5;
        }

        header {
            text-align: center;
            margin-bottom: 2rem;
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 1.5rem;
        }

        h1 {
            font-size: 2rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #f1f5f9;
        }

        p.subtitle {
            color: var(--text-muted);
            margin-top: 0.5rem;
        }

        .main-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        @media (min-width: 1024px) {
            .main-container {
                grid-template-columns: 1fr 1fr;
            }
            .matrix-section {
                grid-column: span 2;
            }
        }

        .faction-panel {
            background-color: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.5rem;
        }

        .panel-title {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 1.25rem;
            text-transform: uppercase;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border-color);
        }

        .logo-placeholder {
            width: 40px;
            height: 32px;
            background-color: var(--border-color);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 0.75rem;
            color: var(--faction-highlight);
            border: 1px solid var(--faction-highlight);
        }

        .category-toggle-container {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .toggle-btn {
            background-color: var(--bg-dark);
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            padding: 0.55rem 0.4rem;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.74rem;
            letter-spacing: 1px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
            min-width: 0;
        }

        .toggle-btn:hover {
            border-color: var(--text-main);
            color: var(--text-main);
        }

        .toggle-btn.active {
            background-color: var(--btn-active-blue);
            border-color: var(--faction-highlight);
            color: white;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        select {
            width: 100%;
            background-color: var(--bg-dark);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.75rem;
            border-radius: 6px;
            font-size: 1rem;
            outline: none;
            cursor: pointer;
        }

        select:focus {
            border-color: var(--faction-highlight);
        }

        .dp-counter {
            display: inline-block;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.875rem;
            font-weight: bold;
            margin-left: auto;
        }

        .dp-under { background-color: rgba(34, 197, 94, 0.2); color: var(--accent-green); }
        .dp-max { background-color: rgba(56, 189, 248, 0.2); color: var(--faction-highlight); }

        .detachment-list {
            display: grid;
            gap: 0.5rem;
            margin-top: 0.5rem;
            max-height: 340px;
            overflow-y: auto;
            padding-right: 0.5rem;
        }

        .detachment-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: var(--bg-dark);
            border: 1px solid var(--border-color);
            padding: 0.75rem;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .detachment-item:hover:not(.disabled) {
            border-color: var(--text-muted);
        }

        .detachment-item.selected {
            border-color: var(--faction-highlight);
            background-color: rgba(56, 189, 248, 0.05);
        }

        .detachment-item.disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .detachment-info {
            display: flex;
            flex-direction: column;
        }

        .detachment-name {
            font-weight: 600;
            font-size: 0.95rem;
        }

        .detachment-source {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.15rem;
        }
        .source-chapter { color: var(--faction-highlight); }
        .source-codex { color: #e2e8f0; opacity: 0.6; }

        .disposition-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .disp-icon {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }
        .disp-purge { background-color: #ef4444; }
        .disp-priority { background-color: #f59e0b; }
        .disp-disruption { background-color: #a855f7; }
        .disp-recon { background-color: #06b6d4; }
        .disp-take { background-color: #10b981; }

        .dp-badge {
            background-color: var(--border-color);
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: bold;
        }

        .matrix-section {
            background-color: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.5rem;
            margin-top: 1rem;
        }

        .matrix-legend {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .force-summary-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        @media (min-width: 900px) {
            .force-summary-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .force-summary-panel {
            background: var(--bg-dark);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem;
        }

        .force-summary-panel h3 {
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.75rem;
            color: var(--text-main);
        }

        .matrix-choice-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        @media (min-width: 900px) {
            .matrix-choice-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .matrix-choice-panel {
            background: var(--bg-dark);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem;
        }

        .matrix-choice-panel h3 {
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .chip-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            margin-top: 0.75rem;
        }

        .chip {
            display: inline-flex;
            align-items: center;
            padding: 0.3rem 0.55rem;
            border-radius: 999px;
            border: 1px solid var(--border-color);
            background: rgba(255, 255, 255, 0.03);
            color: var(--text-muted);
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .matchup-card {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            background: linear-gradient(180deg, rgba(18, 26, 34, 0.95), rgba(10, 15, 20, 0.98));
            border: 1px solid rgba(56, 189, 248, 0.25);
            border-radius: 14px;
            padding: 1.25rem;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
        }

        .matchup-card-topline {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            color: var(--text-muted);
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }

        .matchup-card-main {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 1rem;
            align-items: center;
        }

        @media (max-width: 720px) {
            .matchup-card-main {
                grid-template-columns: 1fr;
            }
        }

        .matchup-side {
            background: var(--bg-dark);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1rem;
            min-height: 120px;
        }

        .matchup-side-label {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 0.35rem;
            font-weight: 700;
        }

        .matchup-side-title {
            font-size: 1rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 0.35rem;
        }

        .matchup-vs {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--faction-highlight);
            font-weight: 800;
            text-align: center;
        }

        .matchup-result {
            background: rgba(56, 189, 248, 0.08);
            border: 1px solid rgba(56, 189, 248, 0.35);
            border-radius: 12px;
            padding: 1rem;
            text-align: center;
        }

        .matchup-result-title {
            font-size: 1.25rem;
            font-weight: 900;
            color: var(--text-main);
            margin-bottom: 0.4rem;
        }

        .matchup-result-subtitle {
            color: var(--text-muted);
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }

        .matchup-empty {
            color: var(--text-muted);
            font-size: 0.9rem;
            text-align: center;
            padding: 1rem 0;
        }

        .selected-deployment-list {
            display: grid;
            gap: 0.5rem;
        }

        .disposition-matrix {
            display: grid;
            grid-template-columns: 180px repeat(5, minmax(0, 1fr));
            gap: 0.5rem;
            align-items: stretch;
        }

        .matrix-card {
            background: var(--bg-dark);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 0.85rem;
            min-height: 96px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        }

        .matrix-card:hover {
            transform: translateY(-1px);
            border-color: var(--text-muted);
        }

        .matrix-card.header-card {
            background: rgba(56, 189, 248, 0.08);
            border-color: rgba(56, 189, 248, 0.35);
        }

        .matrix-card.row-header {
            background: rgba(56, 189, 248, 0.06);
            border-color: rgba(56, 189, 248, 0.25);
        }

        .matrix-card.cell-card {
            position: relative;
            overflow: hidden;
        }

        .matrix-card.cell-card.active-row,
        .matrix-card.cell-card.active-column {
            border-color: rgba(56, 189, 248, 0.55);
            box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.18);
        }

        .matrix-card.cell-card.active-match {
            border-color: var(--faction-highlight);
            box-shadow: 0 0 0 1px rgba(56, 189, 248, 0.25), 0 0 24px rgba(56, 189, 248, 0.08);
        }

        .matrix-card .matrix-disposition {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 0.35rem;
            font-weight: 700;
        }

        .matrix-card .matrix-card-title {
            font-size: 0.92rem;
            font-weight: 700;
            color: var(--text-main);
            line-height: 1.2;
        }

        .matrix-card .matrix-card-subtitle {
            margin-top: 0.35rem;
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .matrix-card.mirror-card .matrix-card-subtitle {
            color: var(--faction-highlight);
        }

        .matrix-card.corner-card {
            background: linear-gradient(135deg, rgba(29, 78, 216, 0.18), rgba(15, 23, 42, 0.95));
            border-style: dashed;
        }

        .matrix-card.corner-card .matrix-card-title {
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        .matrix-card.corner-card .matrix-card-subtitle {
            color: var(--text-main);
            font-size: 0.95rem;
            margin-top: 0.25rem;
            text-transform: none;
            letter-spacing: 0;
        }

        .matrix-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        .matrix-table th, .matrix-table td {
            border: 1px solid var(--border-color);
            padding: 1rem;
            text-align: left;
            vertical-align: top;
        }

        .matrix-table th {
            background-color: var(--bg-dark);
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .matrix-role {
            font-weight: bold;
            display: inline-block;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.8rem;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        .role-attacker { background-color: rgba(239, 68, 68, 0.2); color: var(--accent-red); }
        .role-defender { background-color: rgba(56, 189, 248, 0.2); color: var(--faction-highlight); }

        .summary-block {
            background-color: var(--bg-dark);
            padding: 0.5rem 0.75rem;
            border-radius: 4px;
            margin-bottom: 0.5rem;
            border-left: 3px solid var(--border-color);
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <header>
        <h1>WH40k 11th Edition Force Disposition Matrix</h1>
        <p class="subtitle">Multi-Faction Detachment Configuration Engine (With Cross-Codex Synergies)</p>
    </header>

    <div class="main-container">
        <!-- ROSTER PANEL 1 -->
        <div class="faction-panel" id="panel-1">
            <div class="panel-title">
                <div class="logo-placeholder" id="logo-1">F1</div>
                <h2>Combat Detachment Force A</h2>
                <span class="dp-counter dp-under" id="dp-count-1">0 / 3 DP</span>
            </div>
            
            <label>1. Select Grand Category</label>
            <div class="category-toggle-container">
                <button type="button" class="toggle-btn" id="btn-imperium-1" onclick="switchCategory(1, 'imperium')">Imperium</button>
                <button type="button" class="toggle-btn" id="btn-space-marines-1" onclick="switchCategory(1, 'space_marines')">Space Marines</button>
                <button type="button" class="toggle-btn" id="btn-chaos-1" onclick="switchCategory(1, 'chaos')">Chaos</button>
                <button type="button" class="toggle-btn" id="btn-xenos-1" onclick="switchCategory(1, 'xenos')">Xenos</button>
            </div>

            <div class="form-group">
                <label for="army-select-1">2. Select Specific Faction</label>
                <select id="army-select-1" onchange="loadActiveDeployments(1)" disabled>
                    <option value="">-- Choose Category First --</option>
                </select>
            </div>

            <label>Available Deployments (Max 3 DP)</label>
            <div class="detachment-list" id="detachment-list-1">
                <p style="color: var(--text-muted); font-size: 0.9rem;">Select a grand category and sub-faction above...</p>
            </div>
        </div>

        <!-- ROSTER PANEL 2 -->
        <div class="faction-panel" id="panel-2">
            <div class="panel-title">
                <div class="logo-placeholder" id="logo-2">F2</div>
                <h2>Combat Detachment Force B</h2>
                <span class="dp-counter dp-under" id="dp-count-2">0 / 3 DP</span>
            </div>
            
            <label>1. Select Grand Category</label>
            <div class="category-toggle-container">
                <button type="button" class="toggle-btn" id="btn-imperium-2" onclick="switchCategory(2, 'imperium')">Imperium</button>
                <button type="button" class="toggle-btn" id="btn-space-marines-2" onclick="switchCategory(2, 'space_marines')">Space Marines</button>
                <button type="button" class="toggle-btn" id="btn-chaos-2" onclick="switchCategory(2, 'chaos')">Chaos</button>
                <button type="button" class="toggle-btn" id="btn-xenos-2" onclick="switchCategory(2, 'xenos')">Xenos</button>
            </div>

            <div class="form-group">
                <label for="army-select-2">2. Select Specific Faction</label>
                <select id="army-select-2" onchange="loadActiveDeployments(2)" disabled>
                    <option value="">-- Choose Category First --</option>
                </select>
            </div>

            <label>Available Deployments (Max 3 DP)</label>
            <div class="detachment-list" id="detachment-list-2">
                <p style="color: var(--text-muted); font-size: 0.9rem;">Select a grand category and sub-faction above...</p>
            </div>
        </div>

        <!-- ENGAGEMENT MATRIX SECTION -->
        <div class="matrix-section">
            <div class="panel-title">
                <h2>Tactical Engagement Matrix Breakdown</h2>
            </div>

            <div class="matrix-legend">
                <span>▼ You Play</span>
                <span>▶ Opponent Plays</span>
            </div>

            <div class="force-summary-grid">
                <div class="force-summary-panel">
                    <h3 id="attacker-faction-name">None Loaded</h3>
                    <div class="selected-deployment-list" id="attacker-matrix-content">
                        <p style="color: var(--text-muted);">Awaiting force customization deployment data...</p>
                    </div>
                </div>
                <div class="force-summary-panel">
                    <h3 id="defender-faction-name">None Loaded</h3>
                    <div class="selected-deployment-list" id="defender-matrix-content">
                        <p style="color: var(--text-muted);">Awaiting force customization deployment data...</p>
                    </div>
                </div>
            </div>

            <div class="matrix-choice-grid">
                <div class="matrix-choice-panel">
                    <h3>Choose Your Disposition</h3>
                    <select id="matrix-your-disposition" onchange="renderMatrix()" disabled>
                        <option value="">Select a deployment first</option>
                    </select>
                    <div class="chip-list" id="matrix-your-disposition-chips"></div>
                </div>
                <div class="matrix-choice-panel">
                    <h3>Choose Opponent Disposition</h3>
                    <select id="matrix-opponent-disposition" onchange="renderMatrix()" disabled>
                        <option value="">Select a deployment first</option>
                    </select>
                    <div class="chip-list" id="matrix-opponent-disposition-chips"></div>
                </div>
            </div>

            <div id="force-disposition-matrix"></div>
        </div>
    </div>

