        function sortByDpThenName(left, right) {
            return left.dp - right.dp || left.name.localeCompare(right.name) || left.origin.localeCompare(right.origin);
        }

        function getSelectedDispositions(panelId) {
            const ordered = [];
            state[panelId].deployments.forEach(deployment => {
                if (!ordered.includes(deployment.disp)) {
                    ordered.push(deployment.disp);
                }
            });

            return ordered.sort((left, right) => dispositionOrder.indexOf(left) - dispositionOrder.indexOf(right));
        }

        function renderForceSummary(panelId, containerId, accentColor, emptyMessage) {
            const panel = state[panelId];
            const container = document.getElementById(containerId);

            if (!panel.faction) {
                container.innerHTML = `<p style="color: var(--text-muted);">${emptyMessage}</p>`;
                return;
            }

            if (panel.deployments.length === 0) {
                container.innerHTML = '<p style="color: var(--accent-red); font-size: 0.9rem;">⚠️ No Detachments Active.</p>';
                return;
            }

            let html = '';
            panel.deployments.forEach(deployment => {
                html += `
                    <div class="summary-block" style="border-left-color: ${accentColor};">
                        <span style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase; font-weight:bold;">${deployment.origin}</span><br/>
                        <strong>${deployment.name}</strong> <span style="font-size:0.8rem; color:var(--text-muted);">(${deployment.dp}DP)</span><br/>
                        <span class="disposition-badge"><span class="disp-icon ${dispositionClasses[deployment.disp]}"></span>${deployment.disp}</span>
                    </div>
                `;
            });

            container.innerHTML = html;
        }

        function populateDispositionSelect(selectId, chipContainerId, dispositions, placeholder) {
            const select = document.getElementById(selectId);
            const chips = document.getElementById(chipContainerId);

            chips.innerHTML = '';
            select.innerHTML = '';

            if (dispositions.length === 0) {
                select.disabled = true;
                select.innerHTML = `<option value="">${placeholder}</option>`;
                chips.innerHTML = '<span class="chip">No dispositions selected</span>';
                return;
            }

            select.disabled = false;
            dispositions.forEach((disposition, index) => {
                const option = document.createElement('option');
                option.value = disposition;
                option.textContent = disposition;
                if (index === 0) {
                    option.selected = true;
                }
                select.appendChild(option);

                const chip = document.createElement('span');
                chip.className = 'chip';
                chip.textContent = disposition;
                chips.appendChild(chip);
            });
        }

        function buildDispositionMatrix(attackerDispositions, defenderDispositions) {
            const matrixContainer = document.getElementById("force-disposition-matrix");
            const yourSelect = document.getElementById("matrix-your-disposition");
            const opponentSelect = document.getElementById("matrix-opponent-disposition");
            const yourDisposition = yourSelect.value || attackerDispositions[0] || "";
            const opponentDisposition = opponentSelect.value || defenderDispositions[0] || "";

            populateDispositionSelect("matrix-your-disposition", "matrix-your-disposition-chips", attackerDispositions, "Select a deployment first");
            populateDispositionSelect("matrix-opponent-disposition", "matrix-opponent-disposition-chips", defenderDispositions, "Select a deployment first");

            if (attackerDispositions.includes(yourDisposition)) {
                yourSelect.value = yourDisposition;
            }
            if (defenderDispositions.includes(opponentDisposition)) {
                opponentSelect.value = opponentDisposition;
            }

            const activeYourDisposition = yourSelect.value;
            const activeOpponentDisposition = opponentSelect.value;

            if (!activeYourDisposition || !activeOpponentDisposition) {
                matrixContainer.innerHTML = '<div class="matchup-empty">Select one disposition from each side to reveal the relevant matchup card.</div>';
                return;
            }

            const title = forceDispositionMatrix[activeYourDisposition][activeOpponentDisposition];
            const isMirror = activeYourDisposition === activeOpponentDisposition;

            matrixContainer.innerHTML = `
                <div class="matchup-card">
                    <div class="matchup-card-topline">
                        <span>You Play: ${activeYourDisposition}</span>
                        <span>Opponent Plays: ${activeOpponentDisposition}</span>
                    </div>
                    <div class="matchup-card-main">
                        <div class="matchup-side">
                            <div class="matchup-side-label">You</div>
                            <div class="matchup-side-title">${activeYourDisposition}</div>
                            <div class="matchup-side-label">Selected disposition</div>
                        </div>
                        <div class="matchup-vs">VS</div>
                        <div class="matchup-side">
                            <div class="matchup-side-label">Opponent</div>
                            <div class="matchup-side-title">${activeOpponentDisposition}</div>
                            <div class="matchup-side-label">Selected disposition</div>
                        </div>
                    </div>
                    <div class="matchup-result">
                        <div class="matchup-result-title">${title}</div>
                        <div class="matchup-result-subtitle">${isMirror ? 'Mirror matchup' : 'Force match up card from the matrix'}</div>
                    </div>
                </div>
            `;
        }

        const dispositionClasses = {
