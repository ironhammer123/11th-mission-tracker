                    <!-- Card Top Header Band -->
                    <div class="flex justify-between items-center px-4 py-2 bg-[#eae3d2] border-b border-[#d3c8a9]">
                        <span class="text-[9px] font-black tracking-[0.25em] text-[#726242] uppercase font-cinzel">PRIMARY MISSION</span>
                        <div class="w-7 h-7 ${meta.headerBg} rounded-full flex items-center justify-center text-white shadow-sm">
                            <i class="fa-solid ${meta.icon} text-xs"></i>
                        </div>
                    </div>

                    <!-- Title Body Header block -->
                    <div class="px-4 pt-3 pb-2">
                        <h1 class="text-xl md:text-2xl font-black font-cinzel text-slate-900 uppercase tracking-wide leading-tight">${missionTitle}</h1>
                    </div>
            `;

            if (data.setup) {
                html += `
                    <div class="mx-4 mb-4 p-3 bg-amber-50/60 border-l-4 border-amber-600/80 rounded-r text-[11px] text-slate-700 leading-relaxed font-medium">
                        <strong class="uppercase text-[9px] tracking-wider text-amber-800 block mb-0.5">MISSION SETUP DIRECTIVE</strong>
                        ${data.setup}
                    </div>
                `;
            }

            if (data.global_rule) {
                html += `
                    <div class="mx-4 mb-4 p-3 bg-red-50/60 border-l-4 border-red-700 text-[11px] text-slate-700 leading-relaxed font-semibold">
                        ${data.global_rule}
                    </div>
                `;
            }

            // Render structured Timing Blocks
            html += `<div class="px-4 pb-4 space-y-4">`;
            data.blocks.forEach(block => {
                html += `
                    <div class="bg-white border border-[#eae3d2] rounded-lg shadow-sm overflow-hidden">
                        <!-- Timing block header strip (navy blue) -->
                        <div class="bg-[#11233d] text-white text-[9px] md:text-[10px] font-extrabold tracking-widest px-3 py-1.5 uppercase flex justify-between items-center">
                            <span>${block.timing}</span>
                            <span class="text-[8px] text-[#8ea7c5] font-black tracking-wider uppercase">VP</span>
                        </div>
                `;

                if (block.when) {
                    html += `
                        <div class="bg-[#f0f4f8] px-3 py-1.5 border-b border-[#d3c8a9]/40 flex items-center gap-2">
                            <span class="bg-[#11233d] text-white text-[8px] font-black uppercase px-1.5 py-0.5 rounded-sm flex-shrink-0 tracking-wider">● WHEN</span>
                            <span class="text-[10px] font-bold text-slate-700 italic">${block.when}</span>
                        </div>
                    `;
                }

                html += `<div class="divide-y divide-[#d3c8a9]/20">`;
                block.rows.forEach((row, rIdx) => {
                    if (rIdx > 0 && row.separator) {
                        html += `
                            <div class="relative flex py-1 items-center justify-center px-4">
                                <div class="flex-grow border-t border-dashed border-[#d3c8a9]"></div>
                                <span class="flex-shrink mx-3 text-[8px] font-black bg-[#911f1f] text-white px-2 py-0.5 rounded uppercase tracking-wider shadow">${row.separator}</span>
                                <div class="flex-grow border-t border-dashed border-[#d3c8a9]"></div>
                            </div>
                        `;
                    }

                    html += `
                        <div class="p-3 flex items-center justify-between gap-4">
                            <div class="flex-grow">
                    `;

                    if (row.cumulative) {
                        html += `
                            <div class="inline-flex bg-[#cda02c] text-white text-[8px] font-black uppercase px-2 py-0.5 rounded-full tracking-wider mb-1 shadow-sm">
                                + CUMULATIVE
                            </div>
                        `;
                    }

                    html += `
                                <p class="text-xs md:text-[13px] text-slate-800 leading-relaxed font-semibold">${row.desc}</p>
                            </div>
                            <!-- Side VP block (dark navy blue square) -->
                            <div class="w-12 h-12 bg-[#11233d] rounded-lg flex flex-col items-center justify-center text-white flex-shrink-0 shadow border border-slate-700/20">
                                <span class="text-xl font-black leading-none">${row.vp}</span>
                                <span class="text-[8px] font-bold text-[#8ea7c5] uppercase tracking-wider mt-0.5">VP</span>
                            </div>
                        </div>
                    `;
                });
                html += `</div></div>`;
            });
            html += `</div>`;

            if (data.action) {
                html += `
                    <div class="m-4 bg-[#fcfaf2] border border-amber-600/30 p-3 rounded-lg text-left">
                        <div class="flex items-center gap-2 mb-1.5 border-b border-[#eae3d2] pb-1.5">
                            <i class="fa-solid fa-gears text-amber-700 text-xs"></i>
                            <span class="text-[9px] font-black text-amber-800 uppercase tracking-widest font-cinzel">OBJECTIVE ACTION: ${data.action.name}</span>
                        </div>
                        <p class="text-[11px] text-slate-600 leading-relaxed">${data.action.text}</p>
                    </div>
                `;
            }

            html += `</div>`;
            return html;
        }

        function buildDispositionMatrix(attackerDispositions, defenderDispositions) {
            const matrixContainer = document.getElementById("force-disposition-matrix");
            const yourSelect = document.getElementById("matrix-your-disposition");
            const opponentSelect = document.getElementById("matrix-opponent-disposition");
            const yourDisposition = yourSelect.value || attackerDispositions[0] || "";
            const opponentDisposition = opponentSelect.value || defenderDispositions[0] || "";

            populateDispositionSelect("matrix-your-disposition", "matrix-your-disposition-chips", attackerDispositions, "Select a deployment first");
            populateDispositionSelect("matrix-opponent-disposition", "matrix-opponent-disposition-chips", defenderDispositions, "Select a deployment first");

            if (attackerDispositions.includes(yourDisposition)) {
                yourSelect.value = yourDisposition;
            }
            if (defenderDispositions.includes(opponentDisposition)) {
                opponentSelect.value = opponentDisposition;
            }

            const activeYourDisposition = yourSelect.value;
            const activeOpponentDisposition = opponentSelect.value;

            if (!activeYourDisposition || !activeOpponentDisposition) {
                matrixContainer.innerHTML = '<div class="text-center py-10 bg-grimdark-950 border border-grimdark-800 text-xs text-slate-500 italic rounded-lg">Select one deployment disposition from each side to generate the tactical matchup breakdown card.</div>';
                return;
            }

            const titleA = forceDispositionMatrix[activeYourDisposition][activeOpponentDisposition];
            const titleB = forceDispositionMatrix[activeOpponentDisposition][activeYourDisposition];
            const isMirror = activeYourDisposition === activeOpponentDisposition;

            let resultsCardHtml = '';
            if (isMirror) {
                resultsCardHtml = `
                    <div class="mt-4 bg-amber-500/5 border border-amber-500/20 p-5 rounded-lg text-center">
                        <p class="text-xs text-amber-500/80 font-bold tracking-wider uppercase mb-3">Mirror Matchup Active</p>
                        <div class="w-full max-w-lg mx-auto">
                            ${generateRulesOutputBlock(titleA, 'border-amber-500', activeYourDisposition)}
                        </div>
                    </div>
                `;
            } else {
                resultsCardHtml = `
                    <div class="mt-4 grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <div class="bg-emerald-500/5 border border-emerald-500/20 p-4 rounded-lg text-center">
                            <p class="text-xs text-emerald-400 font-bold tracking-wider uppercase mb-3">Your Mission (${activeYourDisposition})</p>
                            ${generateRulesOutputBlock(titleA, 'border-emerald-500', activeYourDisposition)}
                        </div>
                        <div class="bg-sky-500/5 border border-sky-500/20 p-4 rounded-lg text-center">
                            <p class="text-xs text-sky-400 font-bold tracking-wider uppercase mb-3">Opponent Mission (${activeOpponentDisposition})</p>
                            ${generateRulesOutputBlock(titleB, 'border-sky-500', activeOpponentDisposition)}
                        </div>
                    </div>
                `;
            }

            matrixContainer.innerHTML = `
                <div class="bg-grimdark-950 border border-amber-500/20 p-5 rounded-xl shadow-lg relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-amber-500/5 rounded-full blur-2xl"></div>
                    <div class="flex justify-between items-center gap-4 flex-wrap border-b border-grimdark-800 pb-2 mb-4 text-[10px] text-slate-500 uppercase font-bold tracking-wider">
                        <span>Your Choice: ${activeYourDisposition}</span>
                        <span>Opponent's Choice: ${activeOpponentDisposition}</span>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-center mb-4">
                        <div class="bg-grimdark-900 border border-grimdark-800 p-3 rounded-lg text-center">
                            <span class="text-[9px] text-slate-500 uppercase tracking-wider font-semibold">You</span>
                            <p class="text-sm font-bold font-cinzel text-slate-100 mt-1">${activeYourDisposition}</p>
                        </div>
                        <div class="text-center font-cinzel text-amber-500 font-black text-sm tracking-widest py-1">VS</div>
                        <div class="bg-grimdark-900 border border-grimdark-800 p-3 rounded-lg text-center">
                            <span class="text-[9px] text-slate-500 uppercase tracking-wider font-semibold">Opponent</span>
                            <p class="text-sm font-bold font-cinzel text-slate-100 mt-1">${activeOpponentDisposition}</p>
                        </div>
                    </div>
                    ${resultsCardHtml}
                </div>
            `;
        }

        function switchCategory(panelId, categoryKey) {
            ['imperium', 'space-marines', 'chaos', 'xenos'].forEach(cat => {
                const btn = document.getElementById(`btn-${cat}-${panelId}`);
                if (btn) {
                    btn.className = "bg-grimdark-950 hover:bg-grimdark-800 border border-grimdark-700 text-[10px] font-bold text-slate-300 py-2 rounded uppercase transition-all tracking-wider";
                }
            });

            const targetKey = categoryKey.replace(/_/g, '-');
            const activeButton = document.getElementById(`btn-${targetKey}-${panelId}`);
            if (activeButton) {
                activeButton.className = "bg-amber-500 text-grimdark-950 border border-amber-600 text-[10px] font-bold py-2 rounded uppercase transition-all tracking-wider shadow-gothic-glow";
            }

            state[panelId].currentCat = categoryKey;
            state[panelId].faction = "";
            state[panelId].deployments = [];

            document.getElementById(`dp-warning-${panelId}`).classList.add('hidden');

            const dropdown = document.getElementById(`army-select-${panelId}`);
            dropdown.disabled = false;
            dropdown.innerHTML = '<option value="">-- Select Faction --</option>';

            Object.keys(allFactionDatabase[categoryKey]).sort((l, r) => l.localeCompare(r)).forEach(fac => {
                let opt = document.createElement("option");
                opt.value = fac;
                opt.textContent = fac;
                dropdown.appendChild(opt);
            });

            document.getElementById(`detachment-list-${panelId}`).innerHTML = 
                '<p class="text-xs text-slate-500 italic">Select sub-faction army configuration options...</p>';
            
            document.getElementById(`logo-${panelId}`).textContent = panelId === 1 ? "YOU" : "OPP";
            updateDPDisplay(panelId);
            renderMatrix();
        }

        function loadActiveDeployments(panelId) {
            const cat = state[panelId].currentCat;
            const faction = document.getElementById(`army-select-${panelId}`).value;

            state[panelId].faction = faction;
            state[panelId].deployments = [];

            document.getElementById(`dp-warning-${panelId}`).classList.add('hidden');

            const listContainer = document.getElementById(`detachment-list-${panelId}`);
            const logoBox = document.getElementById(`logo-${panelId}`);

            if (!faction) {
                listContainer.innerHTML = '<p class="text-xs text-slate-500 italic">Select sub-faction army configuration options...</p>';
                logoBox.textContent = panelId === 1 ? "YOU" : "OPP";
                updateDPDisplay(panelId);
                renderMatrix();
                return;
            }

            logoBox.textContent = allFactionDatabase[cat][faction].short;
            listContainer.innerHTML = "";

            let compiledList = [];

            allFactionDatabase[cat][faction].detachments.forEach(d => {
                compiledList.push({ ...d, origin: 'Native Roster' });
            });

            if (cat === "space_marines" && faction !== "Space Marines (Codex)") {
                allFactionDatabase["space_marines"]["Space Marines (Codex)"].detachments.forEach(codexDet => {
                    if (!prohibitedCodexOptions.includes(codexDet.name)) {
                        compiledList.push({ ...codexDet, origin: 'Codex Base' });
                    }
                });
            }

            compiledList.sort(sortByDpThenName);

            compiledList.forEach((det, index) => {
                const item = document.createElement("div");
                item.className = "flex items-center justify-between bg-grimdark-950 border border-grimdark-700/60 p-2.5 rounded-lg cursor-pointer hover:border-slate-500 transition-all select-none";
                item.id = `det-${panelId}-${index}`;
                item.onclick = () => toggleDeploymentItem(panelId, index, det, compiledList);

                const dispDotClass = dispositionClasses[det.disp] || "bg-slate-500";
                const originLabelClass = det.origin === 'Codex Base' ? 'text-slate-400' : 'text-amber-500/80';

                item.innerHTML = `
                    <div class="truncate mr-2 text-left">
                        <span class="text-[9px] uppercase font-bold ${originLabelClass} block truncate">${det.origin}</span>
                        <span class="text-xs font-semibold text-slate-200 block truncate">${det.name}</span>
                        <span class="flex items-center gap-1 mt-0.5">
                            <span class="w-1.5 h-1.5 rounded-full ${dispDotClass}"></span>
                            <span class="text-[9px] text-slate-400 uppercase font-medium block">${det.disp}</span>
                        </span>
                    </div>
                    <span class="text-[10px] font-bold font-cinzel px-2 py-0.5 rounded bg-grimdark-900 border border-grimdark-800 text-slate-300 flex-shrink-0">${det.dp} DP</span>
                `;
                listContainer.appendChild(item);
            });

            state[panelId].computedPoolRef = compiledList;

            updateDPDisplay(panelId);
            renderMatrix();
        }

        function toggleDeploymentItem(panelId, index, selectedDetachment, currentPool) {
            const activeSelections = state[panelId].deployments;
            const existingIndex = activeSelections.findIndex(d => d.index === index);
            const warningEl = document.getElementById(`dp-warning-${panelId}`);

            warningEl.classList.add('hidden');

            if (existingIndex > -1) {
                activeSelections.splice(existingIndex, 1);
            } else {
                const totalCalculatedDP = activeSelections.reduce((sum, d) => sum + d.dp, 0);
                if (totalCalculatedDP + selectedDetachment.dp > 3) {
                    warningEl.classList.remove('hidden');
                    return;
                }
                activeSelections.push({ index, ...selectedDetachment });
            }

            currentPool.forEach((_, idx) => {
                const elem = document.getElementById(`det-${panelId}-${idx}`);
                if (elem) {
                    elem.classList.remove("border-amber-500", "bg-amber-500/5");
                }
            });

            const newTotalDP = activeSelections.reduce((sum, d) => sum + d.dp, 0);

            currentPool.forEach((det, idx) => {
                const elem = document.getElementById(`det-${panelId}-${idx}`);
                if (!elem) return;

                const isSelected = activeSelections.some(d => d.index === idx);
                if (isSelected) {
                    elem.classList.add("border-amber-500", "bg-amber-500/5");
                }

                if (!isSelected && (newTotalDP + det.dp > 3)) {
                    elem.style.opacity = "0.4";
                    elem.style.cursor = "not-allowed";
                } else {
                    elem.style.opacity = "1";
                    elem.style.cursor = "pointer";
                }
            });

            updateDPDisplay(panelId);
            renderMatrix();
        }

        function updateDPDisplay(panelId) {
            const total = state[panelId].deployments.reduce((sum, d) => sum + d.dp, 0);
            const counter = document.getElementById(`dp-count-${panelId}`);
            counter.textContent = `${total} / 3 DP`;

            if (total === 3) {
                counter.className = "text-xs font-bold font-cinzel px-3 py-1 rounded bg-amber-500 text-grimdark-950 border border-amber-600 shadow-gothic-glow";
            } else {
                counter.className = "text-xs font-bold font-cinzel px-3 py-1 rounded bg-grimdark-950 text-slate-300 border border-grimdark-850";
            }
        }

        function renderMatrix() {
            const attackerPanelIdx = "1";
            const defenderPanelIdx = "2";

            const attacker = state[attackerPanelIdx];
            const defender = state[defenderPanelIdx];

            const attackHeader = document.getElementById("attacker-faction-name");
            const defendHeader = document.getElementById("defender-faction-name");
            
            attackHeader.textContent = attacker.faction ? `Your Force: ${attacker.faction}` : "You (Not Loaded)";
            defendHeader.textContent = defender.faction ? `Opponent's Force: ${defender.faction}` : "Opponent (Not Loaded)";

            renderForceSummary(attackerPanelIdx, "attacker-matrix-content", "#f59e0b", "Deploy configurations in your panel.");
            renderForceSummary(defenderPanelIdx, "defender-matrix-content", "#d4af37", "Deploy configurations in opponent's panel.");

            buildDispositionMatrix(getSelectedDispositions(attackerPanelIdx), getSelectedDispositions(defenderPanelIdx));
        }

        window.addEventListener('DOMContentLoaded', () => {
            renderMatrix();
        });
    </script>
</body>
</html>
