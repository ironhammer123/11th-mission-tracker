            document.getElementById(`btn-chaos-${panelId}`).classList.remove('active');
            document.getElementById(`btn-xenos-${panelId}`).classList.remove('active');
            const activeButtonId = categoryKey === 'imperium' ? `btn-imperium-${panelId}` : `btn-${categoryKey.replace(/_/g, '-')}-${panelId}`;
            document.getElementById(activeButtonId).classList.add('active');

            state[panelId].currentCat = categoryKey;
            state[panelId].faction = "";
            state[panelId].deployments = [];

            const dropdown = document.getElementById(`army-select-${panelId}`);
            dropdown.disabled = false;
            dropdown.innerHTML = '<option value="">-- Select Faction --</option>';

            Object.keys(allFactionDatabase[categoryKey]).sort((left, right) => left.localeCompare(right)).forEach(fac => {
                let opt = document.createElement("option");
                opt.value = fac;
                opt.textContent = fac;
                dropdown.appendChild(opt);
            });

            document.getElementById(`detachment-list-${panelId}`).innerHTML = 
                '<p style="color: var(--text-muted); font-size: 0.9rem;">Select a sub-faction army configuration option...</p>';
            
            document.getElementById(`logo-${panelId}`).textContent = `F${panelId}`;
            updateDPDisplay(panelId);
            renderMatrix();
