        function loadActiveDeployments(panelId) {
            const cat = state[panelId].currentCat;
            const faction = document.getElementById(`army-select-${panelId}`).value;

            state[panelId].faction = faction;
            state[panelId].deployments = [];

            const listContainer = document.getElementById(`detachment-list-${panelId}`);
            const logoBox = document.getElementById(`logo-${panelId}`);

            if (!faction) {
                listContainer.innerHTML = '<p style="color: var(--text-muted); font-size: 0.9rem;">Select a sub-faction army configuration option...</p>';
                logoBox.textContent = `F${panelId}`;
                updateDPDisplay(panelId);
                renderMatrix();
                return;
            }

            logoBox.textContent = allFactionDatabase[cat][faction].short;
            listContainer.innerHTML = "";

            let compiledList = [];

            // 1. Load sub-faction core selections
            allFactionDatabase[cat][faction].detachments.forEach(d => {
                compiledList.push({ ...d, origin: 'Native Roster' });
            });

            // 2. Cross-compatibility injection filter logic for Space Marines
            if (cat === "space_marines" && faction !== "Space Marines (Codex)") {
                allFactionDatabase["space_marines"]["Space Marines (Codex)"].detachments.forEach(codexDet => {
                    if (!prohibitedCodexOptions.includes(codexDet.name)) {
                        compiledList.push({ ...codexDet, origin: 'Codex Base' });
                    }
                });
            }

            compiledList.sort(sortByDpThenName);

            // Render DOM Node Layout Items
            compiledList.forEach((det, index) => {
                const item = document.createElement("div");
                item.className = "detachment-item";
                item.id = `det-${panelId}-${index}`;
                item.onclick = () => toggleDeploymentItem(panelId, index, det, compiledList);

                const dispClass = dispositionClasses[det.disp] || "";
                const labelClass = det.origin === 'Codex Base' ? 'source-codex' : 'source-chapter';

                item.innerHTML = `
                    <div class="detachment-info">
                        <span class="detachment-source ${labelClass}">${det.origin}</span>
                        <span class="detachment-name">${det.name}</span>
                        <span class="disposition-badge">
                            <span class="disp-icon ${dispClass}"></span>
                            ${det.disp}
                        </span>
                    </div>
                    <span class="dp-badge">${det.dp} DP</span>
                `;
                listContainer.appendChild(item);
            });

            state[panelId].computedPoolRef = compiledList;

            updateDPDisplay(panelId);
            renderMatrix();
        }

        function toggleDeploymentItem(panelId, index, selectedDetachment, currentPool) {
            const activeSelections = state[panelId].deployments;
            const existingIndex = activeSelections.findIndex(d => d.index === index);

            if (existingIndex > -1) {
                activeSelections.splice(existingIndex, 1);
            } else {
                const totalCalculatedDP = activeSelections.reduce((sum, d) => sum + d.dp, 0);
                if (totalCalculatedDP + selectedDetachment.dp > 3) {
                    alert("Tactical System Check: Selection exceeds the max threshold ceiling allowance of 3 Detachment Points (DP).");
                    return;
                }
                activeSelections.push({ index, ...selectedDetachment });
            }

            currentPool.forEach((_, idx) => {
                const elem = document.getElementById(`det-${panelId}-${idx}`);
                if (elem) elem.classList.remove("selected");
            });

            const newTotalDP = activeSelections.reduce((sum, d) => sum + d.dp, 0);

            currentPool.forEach((det, idx) => {
                const elem = document.getElementById(`det-${panelId}-${idx}`);
                if (!elem) return;

                const isSelected = activeSelections.some(d => d.index === idx);
                if (isSelected) {
                    elem.classList.add("selected");
                }

                if (!isSelected && (newTotalDP + det.dp > 3)) {
                    elem.classList.add("disabled");
                } else {
                    elem.classList.remove("disabled");
                }
            });

            updateDPDisplay(panelId);
            renderMatrix();
        }

        function updateDPDisplay(panelId) {
            const total = state[panelId].deployments.reduce((sum, d) => sum + d.dp, 0);
            const counter = document.getElementById(`dp-count-${panelId}`);
            counter.textContent = `${total} / 3 DP`;

            if (total === 3) {
                counter.className = "dp-counter dp-max";
            } else {
                counter.className = "dp-counter dp-under";
            }
        }

        function renderMatrix() {
            const attackerPanelIdx = "1";
            const defenderPanelIdx = "2";

            const attacker = state[attackerPanelIdx];
            const defender = state[defenderPanelIdx];

            const attackHeader = document.getElementById("attacker-faction-name");
            const defendHeader = document.getElementById("defender-faction-name");
            attackHeader.textContent = attacker.faction || "None Selected";
            defendHeader.textContent = defender.faction || "None Selected";

            renderForceSummary(attackerPanelIdx, "attacker-matrix-content", "#ef4444", "Configure force data options inside the panel selectors.");
            renderForceSummary(defenderPanelIdx, "defender-matrix-content", "#38bdf8", "Configure force data options inside the panel selectors.");

            buildDispositionMatrix(getSelectedDispositions(attackerPanelIdx), getSelectedDispositions(defenderPanelIdx));
        }
    </script>
</body>
</html>
