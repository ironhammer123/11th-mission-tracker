    <script>
        function sortByDpThenName(left, right) {
            return left.dp - right.dp || left.name.localeCompare(right.name) || left.origin.localeCompare(right.origin);
        }

        function getSelectedDispositions(panelId) {
            const ordered = [];
            state[panelId].deployments.forEach(deployment => {
                if (!ordered.includes(deployment.disp)) {
                    ordered.push(deployment.disp);
                }
            });
            return ordered.sort((left, right) => dispositionOrder.indexOf(left) - dispositionOrder.indexOf(right));
        }

        function renderForceSummary(panelId, containerId, accentColor, emptyMessage) {
            const panel = state[panelId];
            const container = document.getElementById(containerId);

            if (!panel.faction) {
                container.innerHTML = `<p class="text-xs text-slate-500 italic">${emptyMessage}</p>`;
                return;
            }

            if (panel.deployments.length === 0) {
                container.innerHTML = '<p class="text-xs text-rose-400 font-bold flex items-center gap-1">⚠️ No Detachments Active.</p>';
                return;
            }

            let html = '';
            panel.deployments.forEach(deployment => {
                html += `
                    <div class="bg-grimdark-900 border-l-4 border-grimdark-850 p-3 rounded-r-lg shadow" style="border-left-color: ${accentColor};">
                        <div class="flex items-center justify-between">
                            <span class="text-[9px] text-slate-400 uppercase font-bold tracking-wider">${deployment.origin}</span>
                            <span class="text-[10px] font-bold text-amber-500 font-cinzel">${deployment.dp} DP</span>
                        </div>
                        <strong class="text-xs text-slate-200 block truncate">${deployment.name}</strong>
                        <div class="flex items-center gap-1.5 mt-1">
                            <span class="w-1.5 h-1.5 rounded-full ${dispositionClasses[deployment.disp]}"></span>
                            <span class="text-[9px] text-slate-400 uppercase font-semibold">${deployment.disp}</span>
                        </div>
                    </div>
                `;
            });

            container.innerHTML = html;
        }

        function populateDispositionSelect(selectId, chipContainerId, dispositions, placeholder) {
            const select = document.getElementById(selectId);
            const chips = document.getElementById(chipContainerId);

            chips.innerHTML = '';
            select.innerHTML = '';

            if (dispositions.length === 0) {
                select.disabled = true;
                select.innerHTML = `<option value="">${placeholder}</option>`;
                chips.innerHTML = '<span class="px-2 py-0.5 rounded-full text-[9px] font-bold border border-grimdark-800 text-slate-500 bg-grimdark-900">No dispositions</span>';
                return;
            }

            select.disabled = false;
            dispositions.forEach((disposition, index) => {
                const option = document.createElement('option');
                option.value = disposition;
                option.textContent = disposition;
                if (index === 0) {
                    option.selected = true;
                }
                select.appendChild(option);

                const chip = document.createElement('span');
                chip.className = 'px-2 py-0.5 rounded-full text-[9px] font-bold border border-grimdark-700 bg-grimdark-900/60 text-slate-300';
                chip.textContent = disposition;
                chips.appendChild(chip);
            });
        }

        function generateRulesOutputBlock(missionTitle, themeColorClass, parentCategory) {
            const data = missionCardDatabase[missionTitle];
            if (!data) return `<p class="text-xs text-slate-400 italic">No supplemental mission rules available.</p>`;

            const meta = categoryMeta[parentCategory] || { border: "border-t-8 border-t-slate-700 bg-slate-950/10", headerBg: "bg-slate-900", icon: "fa-crosshairs", textColor: "text-slate-400" };

            let html = `
